#!/bin/bash
set -e

cd "$(git rev-parse --show-toplevel)"

echo "Checking gherkin formatting..."
npm run fmt:check

echo "Running tests in apps/elita..."
(cd apps/elita && mix test)

echo "Running tests in apps/el..."
(cd apps/el && mix test)

echo "Running cucumber tests..."
TAPE=replay bundle exec cucumber --format progress

echo "Linting apps/elita..."
(cd apps/elita && mix lint)

echo "Linting apps/el..."
(cd apps/el && mix lint)

echo "All gates passed."
