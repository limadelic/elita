#!/bin/bash
set -e

raw_file="$1"
if [[ -z "$raw_file" ]]; then
  echo "Usage: snap <raw-file>" >&2
  exit 1
fi

if [[ ! -f "$raw_file" ]]; then
  echo "File not found: $raw_file" >&2
  exit 1
fi

python3 -c "
import pyte
screen = pyte.Screen(200, 50)
stream = pyte.Stream(screen)
with open('$raw_file', 'rb') as f:
  stream.feed(f.read().decode('utf-8', errors='ignore'))
print('\n'.join(screen.display))
"

